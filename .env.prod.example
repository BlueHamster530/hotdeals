# 운영 환경변수. 이 파일을 .env.prod 로 복사해 값을 채운다. (.env.prod 는 git 커밋 금지)
# 비밀값은 채팅/저장소에 노출하지 말 것.

# --- PostgreSQL (강력한 비밀번호로! 예: openssl rand -base64 24) ---
POSTGRES_USER=hotdeals
POSTGRES_PASSWORD=CHANGE_ME_strong_random
POSTGRES_DB=hotdeals
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- 수집 (초 단위 주기. CF 사이트 레이트리밋 여유 위해 300 권장) ---
INGEST_INTERVAL_SECONDS=300
HTTP_USER_AGENT=hotdeals-bot/0.1 (personal hotdeal aggregator)

# --- CORS (실제 도메인. 미정이면 http://<서버IP> 로 임시) ---
WEB_ORIGIN=https://your-domain.com

# --- 텔레그램 (보유 중) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- AI 챗봇 (현재 비활성. 켜려면 CHATBOT_ENABLED=true + GEMINI_API_KEY 설정) ---
# 무료 키: aistudio.google.com/apikey
CHATBOT_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
