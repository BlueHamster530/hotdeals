# PostgreSQL 접속 정보 (docker-compose 기본값과 일치)
POSTGRES_USER=hotdeals
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=hotdeals
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 수집 주기 (초). loop 모드에서 사용
INGEST_INTERVAL_SECONDS=120

# HTTP 요청 시 사용할 User-Agent (커뮤니티 ToS 준수: 정직하게 식별)
HTTP_USER_AGENT=hotdeals-bot/0.1 (personal hotdeal aggregator)

# 텔레그램 알림 (요구사항 3). @BotFather에서 봇 생성 후 토큰 입력.
# 비우면 알림 기능 전체 비활성(수집/분석/웹은 정상 동작).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# AI 챗봇 (요구사항 4, Google Gemini). 무료 키: https://aistudio.google.com/apikey
# 비우면 챗봇 비활성(나머지 정상).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
